# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/truck_merged?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/truck_merged?schema=public"

# JWT for admin APIs
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"
ADMIN_SEED_PASSWORD="change-me-admin-password"

# App
NODE_ENV="development"
NEXT_PUBLIC_API_URL="/api"

# Cloudflare R2 uploads (direct upload with signed URL)
R2_ACCOUNT_ID="your-r2-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET="your-r2-bucket-name"
R2_PUBLIC_BASE_URL="https://cdn.example.com/uploads"

# Optional upload limit (bytes), except home_hero_image_url media
MAX_UPLOAD_SIZE=10485760
